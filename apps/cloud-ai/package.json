{
  "name": "@stuardai/cloud-ai",
  "version": "1.0.10",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --no-file-parallelism --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:memory": "vitest run src/memory/conversations.test.ts",
    "test:embedding:integration": "vitest run src/memory/embedding.integration.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "sync:tools": "tsx scripts/sync-tools-to-db.ts",
    "sync:tools:force": "tsx scripts/sync-tools-to-db.ts --force --disable-obsolete",
    "sync:tools:status": "tsx scripts/sync-tools-to-db.ts --status",
    "sync:tools:validate": "tsx scripts/sync-tools-to-db.ts --validate",
    "sync:workflow-docs": "tsx src/sync-workflow-docs-embeddings.ts",
    "sync:workflow-docs:force": "tsx src/sync-workflow-docs-embeddings.ts --force",
    "test:telnyx:sms": "tsx scripts/telnyx-send-test.ts --send",
    "backfill:oauth-encryption": "tsx scripts/backfill-external-account-encryption.ts",
    "backfill:oauth-encryption:check": "tsx scripts/backfill-external-account-encryption.ts --check"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/xai": "^3.0.90",
    "@discordjs/voice": "^0.19.2",
    "@elevenlabs/elevenlabs-js": "^2.35.0",
    "@google-cloud/compute": "^6.7.0",
    "@google-cloud/storage": "^7.13.0",
    "@mastra/core": "^1.34.0",
    "@mastra/libsql": "^1.10.1",
    "@mastra/mcp": "^1.7.0",
    "@mastra/memory": "^1.18.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@stuardai/bots-core": "workspace:*",
    "@polar-sh/sdk": "^0.47.1",
    "@stuardai/workflow-core": "workspace:*",
    "@supabase/supabase-js": "^2.45.4",
    "@tavily/core": "^0.7.1",
    "ai": "^6.0.182",
    "ai-sdk-ollama": "^1.1.0",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "openai": "^4.85.0",
    "prism-media": "^1.3.5",
    "sis-tools": "^0.1.2",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@discordjs/opus": "^0.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.25.0",
    "javascript-obfuscator": "^5.3.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "tsx": "^4.17.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.10"
  }
}
