{
  "name": "@stuardai/cloud-ai",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup src/server.ts --format esm --sourcemap --out-dir dist",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:memory": "vitest run src/memory/conversations.test.ts",
    "test:embedding:integration": "vitest run src/memory/embedding.integration.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "sync:tools": "tsx scripts/sync-tools-to-db.ts",
    "sync:tools:force": "tsx scripts/sync-tools-to-db.ts --force --disable-obsolete",
    "sync:tools:status": "tsx scripts/sync-tools-to-db.ts --status",
    "sync:tools:validate": "tsx scripts/sync-tools-to-db.ts --validate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.44",
    "@ai-sdk/deepseek": "^2.0.15",
    "@ai-sdk/google": "^3.0.18",
    "@ai-sdk/openai": "^3.0.23",
    "@ai-sdk/xai": "^3.0.48",
    "@elevenlabs/elevenlabs-js": "^2.35.0",
    "@google-cloud/compute": "^6.7.0",
    "@google-cloud/storage": "^7.13.0",
    "@mastra/core": "^1.1.0",
    "@mastra/libsql": "^0.16.2",
    "@mastra/mcp": "^0.3.0",
    "@mastra/memory": "^0.15.11",
    "@openrouter/ai-sdk-provider": "^1.4.1",
    "@supabase/supabase-js": "^2.45.4",
    "@tavily/core": "^0.7.1",
    "ai": "^6.0.64",
    "ai-sdk-ollama": "^1.1.0",
    "dotenv": "^16.4.5",
    "openai": "^4.85.0",
    "sis-tools": "^0.1.2",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ws": "^8.5.10",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "tsx": "^4.17.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.10"
  }
}
