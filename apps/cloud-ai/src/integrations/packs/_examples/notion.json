{
  "slug": "notion",
  "name": "Notion",
  "description": "Read pages, databases, and append blocks via the Notion API.",
  "icon": "📝",
  "category": "Productivity",
  "version": "0.1.0",

  "auth": {
    "strategy": { "type": "bearer", "tokenField": "integration_token" },
    "fields": [
      {
        "name": "integration_token",
        "label": "Internal Integration Token",
        "secret": true,
        "required": true,
        "placeholder": "secret_...",
        "hint": "notion.so/my-integrations → New internal integration → Internal integration secret"
      }
    ]
  },

  "outbound_hosts": ["api.notion.com"],

  "ping": {
    "method": "GET",
    "urlTemplate": "https://api.notion.com/v1/users/me",
    "headers": { "Notion-Version": "2022-06-28" }
  },

  "tools": [
    {
      "name": "search",
      "description": "Search pages and databases visible to the integration.",
      "args": {
        "type": "object",
        "properties": {
          "query":     { "type": "string", "description": "Search text — empty returns everything" },
          "page_size": { "type": "integer", "default": 25 },
          "filter":    { "type": "string", "enum": ["page", "database"], "description": "Restrict to one object type" }
        }
      },
      "request": {
        "method": "POST",
        "urlTemplate": "https://api.notion.com/v1/search",
        "headers": { "Notion-Version": "2022-06-28" },
        "body": {
          "kind": "json",
          "value": {
            "query":     "{{args.query}}",
            "page_size": "{{args.page_size}}",
            "filter":    { "value": "{{args.filter}}", "property": "object" }
          }
        }
      }
    },

    {
      "name": "get_page",
      "description": "Retrieve a Notion page by id.",
      "args": {
        "type": "object",
        "properties": {
          "page_id": { "type": "string", "description": "Notion page id (UUID, with or without dashes)" }
        },
        "required": ["page_id"]
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.notion.com/v1/pages/{{args.page_id}}",
        "headers": { "Notion-Version": "2022-06-28" }
      },
      "errorMap": {
        "404": "Page {{args.page_id}} not found or not shared with the integration."
      }
    },

    {
      "name": "query_database",
      "description": "Query rows of a Notion database.",
      "args": {
        "type": "object",
        "properties": {
          "database_id":  { "type": "string" },
          "page_size":    { "type": "integer", "default": 50 },
          "start_cursor": { "type": "string", "description": "Cursor from a prior response" }
        },
        "required": ["database_id"]
      },
      "request": {
        "method": "POST",
        "urlTemplate": "https://api.notion.com/v1/databases/{{args.database_id}}/query",
        "headers": { "Notion-Version": "2022-06-28" },
        "body": {
          "kind": "json",
          "value": {
            "page_size":    "{{args.page_size}}",
            "start_cursor": "{{args.start_cursor}}"
          }
        }
      },
      "pagination": { "style": "cursor", "nextField": "next_cursor", "nextParam": "start_cursor" }
    },

    {
      "name": "append_paragraph",
      "description": "Append a paragraph block of plain text to a page.",
      "args": {
        "type": "object",
        "properties": {
          "page_id": { "type": "string" },
          "text":    { "type": "string", "description": "Text content of the paragraph" }
        },
        "required": ["page_id", "text"]
      },
      "request": {
        "method": "PATCH",
        "urlTemplate": "https://api.notion.com/v1/blocks/{{args.page_id}}/children",
        "headers": { "Notion-Version": "2022-06-28" },
        "body": {
          "kind": "json",
          "value": {
            "children": [
              {
                "object": "block",
                "type": "paragraph",
                "paragraph": {
                  "rich_text": [{ "type": "text", "text": { "content": "{{args.text}}" } }]
                }
              }
            ]
          }
        }
      }
    }
  ]
}
