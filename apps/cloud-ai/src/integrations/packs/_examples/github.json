{
  "slug": "github",
  "name": "GitHub",
  "description": "Read repos, issues, and pull requests via the GitHub REST API (PAT auth).",
  "icon": "🐙",
  "category": "DevOps",
  "version": "0.1.0",

  "auth": {
    "strategy": { "type": "bearer", "tokenField": "personal_access_token", "scheme": "token" },
    "fields": [
      {
        "name": "personal_access_token",
        "label": "Personal Access Token",
        "secret": true,
        "required": true,
        "placeholder": "ghp_... or github_pat_...",
        "hint": "GitHub → Settings → Developer settings → Personal access tokens"
      }
    ]
  },

  "outbound_hosts": ["api.github.com"],

  "ping": {
    "method": "GET",
    "urlTemplate": "https://api.github.com/user"
  },

  "tools": [
    {
      "name": "get_authenticated_user",
      "description": "Return the GitHub user the token belongs to.",
      "args": { "type": "object", "properties": {} },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.github.com/user",
        "headers": { "X-GitHub-Api-Version": "2022-11-28" }
      }
    },

    {
      "name": "list_repos",
      "description": "List repositories accessible to the authenticated user.",
      "args": {
        "type": "object",
        "properties": {
          "per_page": { "type": "integer", "description": "Page size (max 100)", "default": 30 },
          "page":     { "type": "integer", "description": "1-based page", "default": 1 },
          "sort":     { "type": "string", "enum": ["created", "updated", "pushed", "full_name"], "default": "updated" }
        }
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.github.com/user/repos",
        "headers": { "X-GitHub-Api-Version": "2022-11-28" },
        "query": {
          "per_page": "{{args.per_page}}",
          "page": "{{args.page}}",
          "sort": "{{args.sort}}"
        }
      },
      "pagination": { "style": "link-header" }
    },

    {
      "name": "list_issues",
      "description": "List open issues for a repo.",
      "args": {
        "type": "object",
        "properties": {
          "owner": { "type": "string", "description": "Repo owner login" },
          "repo":  { "type": "string", "description": "Repo name" },
          "state": { "type": "string", "enum": ["open", "closed", "all"], "default": "open" }
        },
        "required": ["owner", "repo"]
      },
      "request": {
        "method": "GET",
        "urlTemplate": "https://api.github.com/repos/{{args.owner}}/{{args.repo}}/issues",
        "headers": { "X-GitHub-Api-Version": "2022-11-28" },
        "query": { "state": "{{args.state}}" }
      },
      "errorMap": {
        "404": "Repo {{args.owner}}/{{args.repo}} not found or you don't have access.",
        "403": "GitHub rate limit hit or insufficient scopes."
      }
    },

    {
      "name": "create_issue",
      "description": "Open a new issue in a repo.",
      "args": {
        "type": "object",
        "properties": {
          "owner": { "type": "string" },
          "repo":  { "type": "string" },
          "title": { "type": "string" },
          "body":  { "type": "string" },
          "labels": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["owner", "repo", "title"]
      },
      "request": {
        "method": "POST",
        "urlTemplate": "https://api.github.com/repos/{{args.owner}}/{{args.repo}}/issues",
        "headers": { "X-GitHub-Api-Version": "2022-11-28" },
        "body": {
          "kind": "json",
          "value": {
            "title": "{{args.title}}",
            "body":  "{{args.body}}",
            "labels": "{{args.labels}}"
          }
        }
      }
    }
  ]
}
