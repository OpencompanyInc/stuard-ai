# xAI API key (required for Grok models - balanced tier)
XAI_API_KEY=xai-xxx

# DeepSeek API key (required for DeepSeek Chat - fast tier)
DEEPSEEK_API_KEY=sk-xxx

# Google AI API key (required for routing with Gemini 2.5 Flash + smart tier with Gemini 3 Pro)
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyASps2h7UBih4Qx1Bf9DqqLoz1VNQ9d7Fs

# OpenAI API key (optional, used for embeddings)
OPENAI_API_KEY=sk-xxx

# OpenRouter API key (optional, not currently used)
OPENROUTER_API_KEY=sk-or-xxx

# Perplexity API key (required for web_search tool)
PERPLEXITY_API_KEY=pplx-xxx

# YouTube Data API key (required for YouTube URL parsing tools)
# Get one at https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3)
YOUTUBE_API_KEY=AIzaSyXXX

# AssemblyAI API key (required for speech-to-text / voice dictation)
ASSEMBLYAI_API_KEY=xxx

# Cloud AI WebSocket port
CLOUD_AI_PORT=8082

# Enable Gemini-based model routing (set to 0 to disable and always use gpt-5-medium)
ENABLE_ROUTING=1

# Supabase configuration (required for auth + storage)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Prefer new key names; legacy names are still supported as fallback
# New (preferred):
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx
# Legacy (fallback):
SUPABASE_ANON_KEY=anon-key-from-supabase-project-settings
SUPABASE_SERVICE_ROLE_KEY=service_role_key_from_supabase

# If set to 1, cloud WebSocket requires a valid Supabase access token in each message
REQUIRE_AUTH=1

ENABLE_LOCAL_MEMORY=1

# Pricing per 1M tokens (USD) for each model; used to compute cost and credits
# Defaults reflect: 4.1 = $2 in / $8 out, 5-mini = $0.25 in / $2 out, 5 = $1.25 in / $10 out
PRICE_GPT_4_1_IN_PER_M_USD=2
PRICE_GPT_4_1_OUT_PER_M_USD=8
PRICE_GPT_4_1_CACHED_IN_PER_M_USD=0.5
PRICE_GPT_5_MINI_IN_PER_M_USD=0.25
PRICE_GPT_5_MINI_OUT_PER_M_USD=2
PRICE_GPT_5_MINI_CACHED_IN_PER_M_USD=0.025
PRICE_GPT_5_IN_PER_M_USD=1.25
PRICE_GPT_5_OUT_PER_M_USD=10
PRICE_GPT_5_CACHED_IN_PER_M_USD=0.125

# ElevenLabs TTS pricing used for credit accounting (USD per 1,000 chars)
PRICE_ELEVENLABS_TTS_PER_1K_CHARS_USD=0.30

# Credits conversion
# How many credits per 1 USD of model spend (e.g., 100 = $0.01 per credit)
CREDITS_PER_USD=100

# Monthly credits caps per plan (override as needed). -1 means unlimited.
# Supported plan keys map from profiles.plan (case-insensitive): free, pro, team, business, enterprise
PLAN_FREE_MONTHLY_CREDITS=500
# Set to -1 to derive from plan price minus profit (see PLAN_*_PRICE_USD and PLAN_PROFIT_USD below)
PLAN_PRO_MONTHLY_CREDITS=-1
PLAN_TEAM_MONTHLY_CREDITS=-1
PLAN_BUSINESS_MONTHLY_CREDITS=200000
PLAN_ENTERPRISE_MONTHLY_CREDITS=1000000

# If PLAN_<PLAN>_MONTHLY_CREDITS is -1, monthly credits are derived as:
#   credits = (PLAN_<PLAN>_PRICE_USD - PLAN_<PLAN>_PROFIT_USD|PLAN_PROFIT_USD) * CREDITS_PER_USD
# Example: Pro $25/mo, Team $60/mo, $5 profit retained, rest for usage
PLAN_PRO_PRICE_USD=25
PLAN_TEAM_PRICE_USD=60
# Default profit applied when PLAN_<PLAN>_PROFIT_USD is not set
PLAN_PROFIT_USD=5

CLOUD_PUBLIC_URL=http://localhost:8082

# ═══════════════════════════════════════════════════════════════════════════════
# GCP Cloud Engine — VM Provisioning & Storage (REQUIRED for cloud engine)
# ═══════════════════════════════════════════════════════════════════════════════

# GCP project ID (REQUIRED) — the project where VMs and GCS bucket live
GCP_PROJECT_ID=my-gcp-project-id

# Path to a service account JSON key file.
# If running on GCE/Cloud Run with an attached service account, leave blank.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCS bucket for user data, snapshots, and cold storage
CLOUD_ENGINE_BUCKET=stuard-user-data

# GCE zone for VM creation
GCP_ZONE=us-central1-a

# VM base image (Debian 12 by default)
GCP_VM_IMAGE=projects/debian-cloud/global/images/family/debian-12

# Service account email attached to provisioned VMs (blank = default compute SA)
GCP_VM_SERVICE_ACCOUNT=

# VPC network / subnetwork for VMs
GCP_VM_NETWORK=global/networks/default
GCP_VM_SUBNETWORK=

# Secret used to sign VM agent tokens (JWT). Use a strong random string.
VM_TOKEN_SECRET=change-me-to-a-random-secret

# ─── Dev Settings ────────────────────────────────────────────────────────────
# User ID to use when minting dev VM tokens  (any string is fine for local dev)
DEV_USER_ID=dev-local-user-00000000

# Health check intervals (ms)
VM_HEALTH_CHECK_INTERVAL_MS=300000
VM_HEALTH_STALE_THRESHOLD_MS=90000

# Billing interval for compute usage tracking (ms, default 1 hour)
COMPUTE_BILLING_INTERVAL_MS=3600000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_PATH=/integrations/github/callback
GITHUB_SCOPES=read:user,repo
INTEGRATION_STATE_SECRET=60c962b3c0ab4bb7983f2c5d18d8b0d9adbd7a142f3b32c83f6e078a1d9cc57e

# Google OAuth (per-integration scopes requested at connect time)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_PATH=/integrations/google/callback
# Optional default identity scopes; connect endpoint will add minimal scopes per target
GOOGLE_SCOPES=openid, email, profile, https://www.googleapis.com/auth/userinfo.email

# Microsoft/Outlook OAuth (Azure App Registration)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT=common
MS_REDIRECT_PATH=/integrations/outlook/callback
MS_SCOPES=openid profile offline_access User.Read Mail.Read Mail.Send

# =============================================================================
# SIS (Semantic Integration System) - Tool Selection
# =============================================================================

# Enable in-memory SIS as fallback (recommended: 1)
SIS_ENABLE=1

# Use Supabase-backed semantic search (requires tools synced to tool_embeddings)
# Set to 1 to enable Supabase vector search for tool selection
SIS_USE_SUPABASE=0

# Number of semantically-matched tools to retrieve per query
SIS_TOPK=12

# Similarity threshold (0-1). Lower = more tools, higher = stricter matching
SIS_THRESHOLD=0.25

# Enable debug logging for SIS tool selection
SIS_DEBUG=0

# Embedding model for in-memory SIS fallback (faster, smaller model)
SIS_EMBEDDING_MODEL=text-embedding-3-small
