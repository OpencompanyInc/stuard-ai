{
    "manifest_version": 3,
    "name": "Stuard AI Helper",
    "version": "1.0.0",
    "description": "Browser control extension for Stuard AI",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "alarms",
        "tabs",
        "webNavigation"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "src/background/index.ts",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/index.ts"
            ],
            "all_frames": true,
            "match_about_blank": true,
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "index.html"
    }
}