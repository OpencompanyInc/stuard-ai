{
  "name": "@stuardai/desktop",
  "version": "0.1.35",
  "private": true,
  "main": "dist/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n \"MAIN,RENDERER,ELECTRON\" -c \"magenta,cyan,green\" \"pnpm run dev:main\" \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:main": "node scripts/build-custom-ui-css.cjs && node scripts/build-react-markdown-bundle.cjs && tsup --config tsup.config.ts --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 dist/main/index.js dist/preload/index.js && nodemon --watch dist/main --watch dist/preload --exec \"electron .\"",
    "prebuild:css": "node scripts/build-custom-ui-css.cjs",
    "prebuild:markdown": "node scripts/build-react-markdown-bundle.cjs",
    "build": "pnpm run prebuild:css && pnpm run prebuild:markdown && run-p build:main build:renderer",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "prepare:agent": "node ./scripts/prepare-agent.cjs",
    "start": "electron .",
    "pack": "npm run build && npm run obfuscate && npm run prepare:agent && electron-builder --dir",
    "dist": "npm run build && npm run obfuscate && npm run prepare:agent && electron-builder",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "obfuscate": "javascript-obfuscator ./dist/main --output ./dist/main --compact true --control-flow-flattening true --dead-code-injection true --string-array true --string-array-encoding base64 && javascript-obfuscator ./dist/preload --output ./dist/preload --compact true --control-flow-flattening true --dead-code-injection true --string-array true --string-array-encoding base64 && javascript-obfuscator ./dist/renderer/assets --output ./dist/renderer/assets --compact true --control-flow-flattening true --dead-code-injection true --string-array true --string-array-encoding none"
  },
  "dependencies": {
    "@stuardai/bots-core": "file:../../packages/bots-core",
    "@stuardai/bots-ui": "file:../../packages/bots-ui",
    "@stuardai/chat-ui": "file:../../packages/chat-ui",
    "@stuardai/cloud-client": "file:../../packages/cloud-client",
    "@stuardai/cloud-runtime-ui": "file:../../packages/cloud-runtime-ui",
    "@stuardai/vm-chat": "file:../../packages/vm-chat",
    "@stuardai/workflow-core": "file:../../packages/workflow-core",
    "@polar-sh/sdk": "^0.42.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@supabase/supabase-js": "^2.45.4",
    "@types/three": "^0.183.1",
    "anser": "^1.4.10",
    "chokidar": "^3.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "dompurify": "^3.2.3",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.6.2",
    "escape-carriage": "^1.3.0",
    "framer-motion": "^12.23.24",
    "fs-extra": "^11.2.0",
    "katex": "^0.16.25",
    "koffi": "^3.0.0",
    "lucide-react": "^0.554.0",
    "marked": "^17.0.5",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "node-pty": "^1.0.0",
    "node-record-lpcm16": "^1.0.1",
    "node-window-manager": "^2.2.4",
    "posthog-js": "^1.194.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-force-graph-2d": "^1.29.0",
    "react-markdown": "^10.1.0",
    "react-resize-detector": "^12.3.0",
    "react-textarea-autosize": "^8.5.3",
    "react-virtuoso": "^4.10.4",
    "recharts": "^3.6.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "simplebar": "^6.2.5",
    "simplebar-react": "^3.2.5",
    "sucrase": "^3.35.1",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.2",
    "uiohook-napi": "^1.5.4",
    "uuid": "^9.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^5.3.0",
    "node-gyp": "^12.2.0",
    "nodemon": "^3.0.2",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.31",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.7",
    "terser": "^5.46.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.2.0",
    "vitest": "^4.0.10",
    "wait-on": "^7.0.1"
  },
  "overrides": {
    "@electron/rebuild": {
      "@electron/node-gyp": "npm:node-gyp@^12.2.0"
    }
  },
  "build": {
    "appId": "com.stuardai.assistant",
    "productName": "Stuard AI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/main/**",
      "dist/preload/**",
      "dist/renderer/**",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/node-window-manager/**"
    ],
    "extraResources": [
      {
        "from": "build/agent",
        "to": "agent"
      },
      {
        "from": "resources/wakeword",
        "to": "wakeword"
      },
      {
        "from": "build/.env",
        "to": ".env"
      },
      {
        "from": "icons/icon2.png",
        "to": "icon2.png"
      },
      {
        "from": "icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "beforeBuild": "scripts/electron-before-build.cjs",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        "dir"
      ]
    },
    "linux": {
      "icon": "../website/src/app/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "generic",
      "url": "${UPDATE_BASE_URL:-https://updates.stuard.ai/desktop}",
      "channel": "${UPDATE_CHANNEL:-stable}"
    }
  }
}
