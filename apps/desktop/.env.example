# Vite environment variables for the Electron renderer (supabase auth)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public_anon_key_from_supabase
VITE_CLOUD_AI_URL=http://127.0.0.1:8082

# Azure AD App Registration (desktop main process reads these)
# Set these in your shell before starting Electron (PowerShell example):
#   $env:MS_CLIENT_ID = "00000000-0000-0000-0000-000000000000"
#   $env:MS_TENANT = "common"  # or your tenant ID
MS_CLIENT_ID = 5ba3433d-66f1-4f4c-ab6e-2f73c4c9ffb1

MS_TENANT=consumers
