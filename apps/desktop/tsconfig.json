{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node", "vite/client"],
    "noEmit": false,
    "strict": true
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "tsup.config.ts",
    "tailwind.config.cjs",
    "postcss.config.cjs"
  ],
  "exclude": [
    "src/**/*.backup.tsx",
    "src/**/*.backup.ts"
  ]
}
