.codex-pytest-tmp
.codex-pytest-tmp/**
.pytest_cache
.pytest_cache/**
pytest-cache-files-*
pytest-cache-files-*/
_tmp_docs/
apps/agent/.pytest-local
apps/agent/.pytest-local/**
apps/agent/.pytest-run-*
apps/agent/.pytest-run-*/
