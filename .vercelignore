# apps/agent is a Python project (no package.json) — not a JS workspace member and
# not needed by the website build. Prune the whole tree so Vercel never scandirs
# its process-locked pytest temp dirs (the recurring EPERM source).
apps/agent/
**/.pytest_cache/
**/.codex-pytest-tmp/
# Build artifacts / packaged binaries — regenerated by the remote build and not
# needed by the website. These contain files >100MB that Vercel rejects on upload.
.next/
.turbo/
.vercel/output/
/dist/
apps/desktop/build/
apps/desktop/release/
apps/desktop/dist/
apps/desktop/out/
apps/desktop/whisper_models/
